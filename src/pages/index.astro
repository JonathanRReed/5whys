---
import Base from '../layouts/Base.astro';
import { siteConfig } from '../config/site';

const privacyChips = ['No account', 'Local-only', 'Open source', 'Free'];

// Plates: the four instruments of the field guide. Each carries a real specimen
// of its output so the page shows usefulness, not just promises.
const plates = [
  {
    roman: 'I',
    tag: 'Plate I · Reflect',
    accent: 'foam',
    name: 'The Five Whys',
    href: '/career/',
    cta: 'Open the plate',
    desc: 'Ask why five times until the answer stops moving, and name the motivation underneath the obvious one.',
    caption: 'Specimen · a chain that bottoms out',
  },
  {
    roman: 'II',
    tag: 'Plate II · Prove',
    accent: 'gold',
    name: 'The Resume Game',
    href: '/resume-game/',
    cta: 'Open the plate',
    desc: 'Score each bullet for action, scale, and result, then rewrite weak lines into evidence a recruiter can scan in seconds.',
    caption: 'Specimen · one bullet, rescored',
  },
  {
    roman: 'III',
    tag: 'Plate III · Rehearse',
    accent: 'iris',
    name: 'Networking Practice',
    href: '/networking-practice/',
    cta: 'Open the plate',
    desc: 'Rehearse real introductions against a timer, then debrief each rep so the next conversation feels lighter.',
    caption: 'Specimen · a two-minute opener',
  },
  {
    roman: 'IV',
    tag: 'Plate IV · Prepare',
    accent: 'love',
    name: 'Interview Glow Up',
    href: '/5whys/interview-glow-up/',
    cta: 'Open the plate',
    desc: 'Decode a job description into the skills it really tests, then build proof-based STAR stories for each one.',
    caption: 'Specimen · JD signal to story',
  },
];

const fieldNotes = [
  {
    k: 'Private by default',
    v: 'Every word you write stays in your browser. No accounts, no tracking, nothing sent to a server.',
    c: 'foam',
  },
  {
    k: 'Built for momentum',
    v: 'Guided prompts, timers, and feedback that move you from stuck to a clear next step in one sitting.',
    c: 'gold',
  },
  {
    k: 'Considered and accessible',
    v: 'Full keyboard navigation, high-contrast Night and Dawn themes, and reduced-motion support throughout.',
    c: 'iris',
  },
];

const toolkitItems = plates.map((p) => ({
  name: p.name,
  description: p.desc,
  url: p.href,
}));

const homeStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: '5 Whys Career Studio',
    url: siteConfig.siteUrl,
    description:
      'A field guide to professional life: career reflection, resume refinement, networking rehearsal, and interview preparation tools that run entirely in your browser.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Career field guide plates',
    itemListElement: toolkitItems.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      description: item.description,
      url: new URL(item.url, siteConfig.siteUrl).toString(),
    })),
  },
];
---

<Base
  title="5 Whys Career Studio | A field guide to professional life"
  description="A field guide to professional life by Jonathan R Reed: reflection, resume, networking, and interview tools that help you find the real reason and build the proof. Private, no account."
  theme="night"
  structuredData={homeStructuredData}
>
  <div class="relative space-y-24 overflow-hidden px-4 pb-24 pt-8 sm:space-y-28 sm:pt-10">
    {/* ============================ MASTHEAD ============================ */}
    <div class="fg-rise mx-auto w-full max-w-6xl" style="animation-delay:0.05s">
      <div class="rule-double mb-3"></div>
      <div
        class="flex flex-wrap items-center justify-between gap-x-6 gap-y-1 text-[hsl(var(--muted-foreground))]"
      >
        <span class="eyebrow">5 Whys Career Studio</span>
        <span class="eyebrow hidden text-[hsl(var(--gold))] sm:block"
          >A Field Guide to Professional Life</span
        >
        <span class="eyebrow">Vol. 01</span>
      </div>
      <div class="rule-brass mt-3"></div>
    </div>

    {/* ============================ COVER PLATE / HERO ============================ */}
    <section class="mx-auto grid w-full max-w-6xl gap-12 lg:grid-cols-[1fr_minmax(320px,440px)] lg:items-center">
      <div class="space-y-7">
        <div class="fg-rise flex items-center gap-3" style="animation-delay:0.12s">
          <span class="h-px w-10 bg-[hsl(var(--gold))]" aria-hidden="true"></span>
          <span class="eyebrow" style="color:hsl(var(--gold))">The 5 Whys Method · Plate 00</span>
        </div>

        <h1
          class="fg-rise text-[2.65rem] leading-[1.0] tracking-[-0.02em] text-foreground sm:text-6xl lg:text-[4.1rem]"
          style="animation-delay:0.2s"
        >
          Find the <span class="display-italic text-[hsl(var(--foam))]">real reason</span>.<br />
          Then build the <span class="display-italic text-[hsl(var(--gold))]">proof</span>.
        </h1>

        <p
          class="fg-rise max-w-xl text-pretty text-lg leading-relaxed text-muted-foreground"
          style="animation-delay:0.28s"
        >
          A private studio of four career tools, kept like a field guide. Dig past the obvious
          answer to the motivation underneath it, then turn that clarity into resumes, intros, and
          interview stories you can actually use.
        </p>

        <div class="fg-rise flex flex-wrap items-center gap-3" style="animation-delay:0.36s">
          <a
            href="/career/"
            class="group inline-flex items-center gap-2 rounded-lg bg-[hsl(var(--primary))] px-5 py-3 text-sm font-semibold text-[hsl(var(--primary-foreground))] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_18px_40px_-22px_hsl(var(--primary))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[hsl(var(--ring))] focus-visible:ring-offset-2 focus-visible:ring-offset-[hsl(var(--background))]"
          >
            Start with the 5 Whys
            <svg
              class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="#plates"
            class="inline-flex items-center gap-2 rounded-lg border border-[hsl(var(--border)/0.6)] px-5 py-3 text-sm font-semibold text-foreground transition-colors duration-200 hover:border-[hsl(var(--gold)/0.5)] hover:text-[hsl(var(--gold))]"
          >
            Tour the four plates
          </a>
        </div>

        <div
          class="fg-rise flex flex-wrap gap-x-5 gap-y-2 pt-1"
          style="animation-delay:0.44s"
          aria-label="What this costs you"
        >
          {
            privacyChips.map((chip) => (
              <span class="eyebrow inline-flex items-center gap-2 text-muted-foreground">
                <span class="h-1 w-1 rounded-full bg-[hsl(var(--gold))]" aria-hidden="true" />
                {chip}
              </span>
            ))
          }
        </div>
      </div>

      {/* The signature plate: a botanical diagram of a career decision */}
      <figure
        class="fg-rise relative mx-auto w-full max-w-[440px] overflow-hidden rounded-xl border border-[hsl(var(--border)/0.6)] bg-strata bg-[hsl(var(--card)/0.35)]"
        style="animation-delay:0.32s"
      >
        {/* corner registration ticks */}
        <span class="pointer-events-none absolute left-2.5 top-2.5 h-3 w-3 border-l border-t border-[hsl(var(--gold)/0.55)]" aria-hidden="true"></span>
        <span class="pointer-events-none absolute right-2.5 top-2.5 h-3 w-3 border-r border-t border-[hsl(var(--gold)/0.55)]" aria-hidden="true"></span>
        <span class="pointer-events-none absolute bottom-12 left-2.5 h-3 w-3 border-b border-l border-[hsl(var(--gold)/0.55)]" aria-hidden="true"></span>
        <span class="pointer-events-none absolute bottom-12 right-2.5 h-3 w-3 border-b border-r border-[hsl(var(--gold)/0.55)]" aria-hidden="true"></span>

        <svg
          viewBox="0 0 480 600"
          class="block w-full"
          style="color:hsl(var(--foreground))"
          role="img"
          aria-label="A diagram of a career decision drawn as a plant: the leaf is the answer you give out loud, and the taproot descends through deeper reasons to the root cause, build toward mastery."
        >
          {/* deeper / surface guide ruling */}
          <line x1="34" y1="182" x2="270" y2="182" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="2 5"></line>
          <text x="34" y="174" font-family="'JetBrains Mono Variable', monospace" font-size="10.5" letter-spacing="2" fill="hsl(var(--muted-foreground))">SURFACE</text>

          {/* plant above ground: stem + leaves (the visible answer) */}
          <g class="fg-rise" style="animation-delay:0.5s">
            <path d="M160 182 C160 150 160 120 160 96" fill="none" stroke="hsl(var(--foam))" stroke-width="2.4" stroke-linecap="round"></path>
            <path d="M160 138 C132 132 116 110 118 86 C142 92 160 110 160 138 Z" fill="hsl(var(--foam)/0.14)" stroke="hsl(var(--foam))" stroke-width="1.8"></path>
            <path d="M160 120 C188 112 206 90 204 66 C180 74 160 92 160 120 Z" fill="hsl(var(--foam)/0.14)" stroke="hsl(var(--foam))" stroke-width="1.8"></path>
            <path d="M160 100 C160 84 168 70 182 60" fill="none" stroke="hsl(var(--foam))" stroke-width="1.8" stroke-linecap="round"></path>
          </g>

          {/* rootlets (static) */}
          <g stroke="hsl(var(--foam))" fill="none" stroke-width="1.5" stroke-linecap="round" opacity="0.85">
            <path d="M159 252 C140 258 126 270 112 290"></path>
            <path d="M161 330 C182 338 198 352 214 372"></path>
            <path d="M159 408 C138 416 124 432 110 456"></path>
            <path d="M161 470 C176 478 188 492 198 512"></path>
          </g>

          {/* the taproot: the signature draw-on-load line, surface foam to brass root */}
          <defs>
            <linearGradient id="taproot" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="hsl(var(--foam))"></stop>
              <stop offset="100%" stop-color="hsl(var(--gold))"></stop>
            </linearGradient>
          </defs>
          <path
            class="fg-root-path"
            pathLength="1"
            d="M160 182 C150 232 174 300 160 360 C150 420 168 486 160 540"
            fill="none"
            stroke="url(#taproot)"
            stroke-width="2.8"
            stroke-linecap="round"
          ></path>

          {/* numbered nodes down the descent */}
          <g font-family="'JetBrains Mono Variable', monospace" font-size="11" font-weight="500">
            {/* 01 — the leaf / answer */}
            <g class="fg-label" style="animation-delay:1.0s">
              <line x1="172" y1="112" x2="300" y2="100" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="2 4"></line>
              <circle cx="160" cy="120" r="3.5" fill="hsl(var(--foam))"></circle>
              <text x="306" y="96" fill="hsl(var(--muted-foreground))">01 · the answer</text>
              <text x="306" y="112" font-family="'Fraunces Variable', serif" font-size="15" font-style="italic" fill="hsl(var(--foreground))">“I want to leave.”</text>
            </g>
            {/* 02 */}
            <g class="fg-label" style="animation-delay:1.25s">
              <line x1="160" y1="252" x2="300" y2="252" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="2 4"></line>
              <circle cx="160" cy="252" r="3.5" fill="hsl(var(--background))" stroke="hsl(var(--foam))" stroke-width="1.6"></circle>
              <text x="306" y="249" fill="hsl(var(--muted-foreground))">02</text>
              <text x="306" y="263" font-family="'Fraunces Variable', serif" font-size="14" fill="hsl(var(--foreground))">work stopped mattering</text>
            </g>
            {/* 03 */}
            <g class="fg-label" style="animation-delay:1.45s">
              <line x1="160" y1="330" x2="300" y2="330" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="2 4"></line>
              <circle cx="160" cy="330" r="3.5" fill="hsl(var(--background))" stroke="hsl(var(--foam))" stroke-width="1.6"></circle>
              <text x="306" y="327" fill="hsl(var(--muted-foreground))">03</text>
              <text x="306" y="341" font-family="'Fraunces Variable', serif" font-size="14" fill="hsl(var(--foreground))">I stopped learning</text>
            </g>
            {/* 04 */}
            <g class="fg-label" style="animation-delay:1.65s">
              <line x1="160" y1="408" x2="300" y2="408" stroke="hsl(var(--border))" stroke-width="1" stroke-dasharray="2 4"></line>
              <circle cx="160" cy="408" r="3.5" fill="hsl(var(--background))" stroke="hsl(var(--gold))" stroke-width="1.6"></circle>
              <text x="306" y="405" fill="hsl(var(--muted-foreground))">04</text>
              <text x="306" y="419" font-family="'Fraunces Variable', serif" font-size="14" fill="hsl(var(--foreground))">drifted from my craft</text>
            </g>
            {/* 05 — the root cause */}
            <g class="fg-root-tip">
              <line x1="160" y1="540" x2="300" y2="525" stroke="hsl(var(--gold)/0.6)" stroke-width="1"></line>
              <circle cx="160" cy="540" r="11" fill="hsl(var(--gold)/0.18)"></circle>
              <circle cx="160" cy="540" r="5.5" fill="hsl(var(--gold))"></circle>
              <text x="306" y="518" fill="hsl(var(--gold))" letter-spacing="1.5">05 · ROOT CAUSE</text>
              <text x="306" y="536" font-family="'Fraunces Variable', serif" font-size="16" font-weight="500" fill="hsl(var(--foreground))">build toward mastery</text>
            </g>
          </g>
        </svg>

        <figcaption
          class="flex items-center justify-between border-t border-[hsl(var(--border)/0.5)] px-4 py-2.5"
        >
          <span class="eyebrow">Fig. 1</span>
          <span class="eyebrow text-muted-foreground">Anatomy of a decision</span>
        </figcaption>
      </figure>
    </section>

    {/* ============================ THE PLATES ============================ */}
    <section id="plates" class="reveal mx-auto w-full max-w-6xl scroll-mt-24 space-y-10">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl space-y-3">
          <span class="eyebrow" style="color:hsl(var(--gold))">The instruments · Plates I–IV</span>
          <h2 class="text-3xl text-foreground sm:text-[2.6rem] sm:leading-[1.05]">
            Four plates, <span class="display-italic text-[hsl(var(--foam))]">one throughline</span>.
          </h2>
          <p class="text-pretty text-base text-muted-foreground">
            Each tool stands on its own, but together they trace a single arc: understand the why,
            prove it, rehearse it, and walk in prepared.
          </p>
        </div>
        <div class="eyebrow flex shrink-0 flex-wrap items-center gap-2 text-muted-foreground">
          <span class="text-[hsl(var(--foam))]">Reflect</span>
          <span aria-hidden="true">→</span>
          <span class="text-[hsl(var(--gold))]">Prove</span>
          <span aria-hidden="true">→</span>
          <span class="text-[hsl(var(--iris))]">Rehearse</span>
          <span aria-hidden="true">→</span>
          <span class="text-[hsl(var(--love))]">Prepare</span>
        </div>
      </div>

      <div class="rule-brass"></div>

      <div class="reveal-stagger grid gap-px overflow-hidden rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--border)/0.5)] sm:grid-cols-2">
        {
          plates.map((p) => (
            <a
              href={p.href}
              class="group relative flex flex-col gap-5 bg-[hsl(var(--background))] p-6 transition-colors duration-200 hover:bg-[hsl(var(--card)/0.55)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[hsl(var(--ring))] sm:p-8"
              style={`--p: var(--${p.accent})`}
            >
              <span
                class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-[hsl(var(--p))] transition-transform duration-300 group-hover:scale-x-100"
                aria-hidden="true"
              />
              <div class="flex items-start justify-between gap-4">
                <div class="space-y-2">
                  <span class="eyebrow" style="color:hsl(var(--p))">
                    {p.tag}
                  </span>
                  <h3 class="text-2xl text-foreground">{p.name}</h3>
                </div>
                <span
                  class="plate-numeral select-none text-[3.4rem] text-[hsl(var(--p)/0.5)] transition-colors duration-200 group-hover:text-[hsl(var(--p))]"
                  aria-hidden="true"
                >
                  {p.roman}
                </span>
              </div>

              <p class="text-sm leading-relaxed text-muted-foreground">{p.desc}</p>

              {/* the pinned specimen */}
              <div class="specimen mt-auto p-4">
                <p class="eyebrow mb-3 text-[0.62rem]" style="color:hsl(var(--p))">
                  {p.caption}
                </p>

                {p.roman === 'I' && (
                  <div class="space-y-1.5 font-mono text-xs text-muted-foreground">
                    <p>“more money”</p>
                    <p class="pl-3">↳ “freedom to choose my work”</p>
                    <p class="pl-6 font-semibold text-[hsl(var(--foam))]">↳ build toward mastery</p>
                  </div>
                )}

                {p.roman === 'II' && (
                  <div class="space-y-2 text-xs">
                    <div class="flex items-start gap-2 text-muted-foreground">
                      <span class="num-index shrink-0 text-[hsl(var(--love))]">32</span>
                      <span class="line-through decoration-[hsl(var(--border))]">
                        Helped improve the company website.
                      </span>
                    </div>
                    <div class="flex items-start gap-2 text-foreground">
                      <span class="num-index shrink-0 text-[hsl(var(--gold))]">88</span>
                      <span>Cut homepage load time 40%, lifting signups 12%.</span>
                    </div>
                  </div>
                )}

                {p.roman === 'III' && (
                  <div class="space-y-2 text-xs">
                    <p class="font-display text-sm italic leading-snug text-foreground">
                      “I’m Jordan. I build accessible data tools, and I’m hoping to meet people in
                      civic tech.”
                    </p>
                    <p class="eyebrow text-[0.6rem] text-muted-foreground">
                      <span class="text-[hsl(var(--iris))]">02:00</span> · clarity ●●●○
                    </p>
                  </div>
                )}

                {p.roman === 'IV' && (
                  <div class="space-y-1.5 font-mono text-xs text-muted-foreground">
                    <p>
                      <span class="text-[hsl(var(--love))]">“cross-functional”</span> appears ×3
                    </p>
                    <p class="pl-3 text-foreground">
                      ↳ STAR: shipped billing redesign across design, data, and support
                    </p>
                  </div>
                )}
              </div>

              <span
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-[hsl(var(--p))]"
              >
                {p.cta}
                <svg
                  class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    {/* ============================ FIELD NOTES ============================ */}
    <section class="reveal mx-auto w-full max-w-6xl">
      <div class="grid gap-x-14 gap-y-10 md:grid-cols-[0.85fr_1.15fr]">
        <div class="space-y-4">
          <span class="eyebrow" style="color:hsl(var(--gold))">From the field notes</span>
          <h2 class="text-3xl text-foreground sm:text-[2.4rem] sm:leading-[1.08]">
            Quiet, private, and built to be <span class="display-italic text-[hsl(var(--foam))]">used</span>.
          </h2>
          <p class="dropcap max-w-md text-pretty text-base leading-relaxed text-muted-foreground">
            No dashboards demanding your attention, no streak to maintain. Just focused exercises
            that respect your time and keep every word you write on your own device. Open one before
            an application, come back for interview prep, and leave with language you can reuse.
          </p>
        </div>
        <ul class="self-start bg-ledger">
          {
            fieldNotes.map((row, i) => (
              <li class="flex gap-5 border-t border-[hsl(var(--border)/0.4)] py-5 first:border-t-0 first:pt-0">
                <span class="num-index pt-1 text-sm text-[hsl(var(--muted-foreground))]" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span
                  class="mt-1.5 h-2 w-2 shrink-0 rounded-full"
                  style={`background: hsl(var(--${row.c}))`}
                  aria-hidden="true"
                />
                <div class="space-y-1">
                  <h3 class="text-lg text-foreground">{row.k}</h3>
                  <p class="text-sm leading-relaxed text-muted-foreground">{row.v}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    {/* ============================ COLOPHON / CTA ============================ */}
    <section class="reveal mx-auto w-full max-w-6xl">
      <div class="rule-double"></div>
      <div class="flex flex-col items-start gap-7 py-12 text-left sm:items-center sm:py-16 sm:text-center">
        <span class="eyebrow" style="color:hsl(var(--gold))">Begin the guide</span>
        <h2 class="max-w-3xl text-4xl leading-[1.02] text-foreground sm:text-5xl">
          Start where every good decision starts: <span class="display-italic text-[hsl(var(--foam))]">why</span>.
        </h2>
        <a
          href="/career/"
          class="group inline-flex items-center gap-2 rounded-lg bg-[hsl(var(--primary))] px-6 py-3.5 text-sm font-semibold text-[hsl(var(--primary-foreground))] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_18px_40px_-22px_hsl(var(--primary))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[hsl(var(--ring))] focus-visible:ring-offset-2 focus-visible:ring-offset-[hsl(var(--background))]"
        >
          Start with the 5 Whys
          <svg
            class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <p class="eyebrow max-w-md text-[0.62rem] leading-relaxed text-muted-foreground">
          Set in Fraunces, Inter &amp; JetBrains Mono · Made by Jonathan R Reed · No account, no
          tracking
        </p>
      </div>
      <div class="rule-brass"></div>
    </section>

    {/* SEO context — visually hidden, server-rendered */}
    <section class="sr-only" aria-label="Career studio search context">
      <h2>Career reflection and preparation toolkit overview</h2>
      <p>
        5 Whys Career Studio is a browser-based field guide to professional life: a set of career
        planning, resume review, networking rehearsal, and interview preparation tools by Jonathan R
        Reed. It connects the guided five whys reflection workflow with practical exercises for
