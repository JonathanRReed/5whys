---
import Base from '../layouts/Base.astro';
import NetworkingPracticeApp from '../components/NetworkingPractice';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/networking-practice/', siteConfig.siteUrl).toString();
const networkingSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': `${pageUrl}#app`,
    name: 'Networking Practice Studio',
    url: pageUrl,
    applicationCategory: 'ProductivityApplication',
    operatingSystem: 'Web',
    description:
      'Guided scenarios, prompts, and a built-in two minute timer that make networking reps intentional and reflective.',
    creator: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    image: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.7',
      ratingCount: '9',
      bestRating: '5',
      worstRating: '1',
    },
  },
];
---
<Base
  title="Networking Practice Studio"
  description="Rehearse confident intros, cycle through curated prompts, time each networking rep, and log takeaways for better follow-up."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Networking Practice', href: '/networking-practice/' },
  ]}
  structuredData={networkingSchemas}
>
  <div class="relative overflow-hidden px-4 pb-16 pt-4 sm:pt-6">
    <h1 class="sr-only">Networking Practice Studio</h1>
    <section class="mx-auto w-full max-w-6xl">
      <NetworkingPracticeApp
        client:load
        showHeader={false}
        className="pb-8"
      />
    </section>
  </div>
</Base>
