---
import Base from '../layouts/Base.astro';
import NetworkingPracticeApp from '../components/NetworkingPractice';
import ErrorBoundary from '../components/shared/ErrorBoundary';
import WithToasts from '../components/WithToasts';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/networking-practice/', siteConfig.siteUrl).toString();
const networkingSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': `${pageUrl}#app`,
    name: 'Networking Practice Studio',
    url: pageUrl,
    applicationCategory: 'ProductivityApplication',
    operatingSystem: 'Web',
    description:
      'Guided scenarios, prompts, and a built-in two minute timer that make networking reps intentional and reflective.',
    creator: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    image: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.7',
      ratingCount: '9',
      bestRating: '5',
      worstRating: '1',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How long should I practice each scenario?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Each scenario includes a 2-minute timer. Most people find that 2-3 reps per scenario builds confidence without fatigue.',
        },
      },
      {
        '@type': 'Question',
        name: 'Are the scenarios based on real situations?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Each scenario is crafted around common networking contexts like career fairs, coffee chats, virtual events, and alumni meetups.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I create my own scenarios?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. You can customize any scenario or create entirely new versions with your own prompts, audience, and context.',
        },
      },
    ],
  },
];
---
<Base
  title="Networking Practice Studio"
  description="Rehearse confident intros, cycle through curated prompts, time each networking rep, and log takeaways for better follow-up."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Networking Practice', href: '/networking-practice/' },
  ]}
  structuredData={networkingSchemas}
>
  <div class="relative overflow-hidden px-4 pb-16 pt-4 sm:pt-6">
    <h1 class="sr-only">Networking Practice Studio</h1>
    <section class="mx-auto w-full max-w-6xl">
      <ErrorBoundary client:load>
        <WithToasts client:load>
          <NetworkingPracticeApp
            client:load
            showHeader={false}
            className="pb-8"
          />
        </WithToasts>
      </ErrorBoundary>
    </section>
  </div>
</Base>
