---
import Base from '../layouts/Base.astro';
import NetworkingPracticeApp from '../components/NetworkingPractice';
import ErrorBoundary from '../components/shared/ErrorBoundary';
import WithToasts from '../components/WithToasts';

const networkingSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How long should I practice each scenario?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Each scenario includes a 2-minute timer. Most people find that 2-3 reps per scenario builds confidence without fatigue.',
        },
      },
      {
        '@type': 'Question',
        name: 'Are the scenarios based on real situations?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Each scenario is crafted around common networking contexts like career fairs, coffee chats, virtual events, and alumni meetups.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I create my own scenarios?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. You can customize any scenario or create entirely new versions with your own prompts, audience, and context.',
        },
      },
    ],
  },
];
---

<Base
  title="Networking Practice Studio"
  description="Rehearse confident intros, cycle through curated prompts, time each networking rep, and log takeaways for better follow-up."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Networking Practice', href: '/networking-practice/' },
  ]}
  structuredData={networkingSchemas}
>
  <div class="relative overflow-hidden px-4 pb-16 pt-4 sm:pt-6">
    <h1 class="sr-only">Networking Practice Studio</h1>
    <section class="mx-auto w-full max-w-6xl">
      <ErrorBoundary client:load>
        <WithToasts client:load>
          <NetworkingPracticeApp client:load showHeader={false} className="pb-8" />
        </WithToasts>
      </ErrorBoundary>
    </section>

    {/* Quick Stats */}
    <section
      class="mx-auto mt-10 grid w-full max-w-6xl grid-cols-2 gap-3 sm:grid-cols-4 reveal"
      aria-label="Networking practice quick stats"
    >
      <div
        class="flex items-center gap-3 rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] px-4 py-3"
      >
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--iris)/0.15)]"
        >
          <svg
            class="h-4 w-4 text-[hsl(var(--iris))]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"
            ></path>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">10+ scenarios</p>
          <p class="text-[10px] text-muted-foreground">Curated contexts</p>
        </div>
      </div>
      <div
        class="flex items-center gap-3 rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] px-4 py-3"
      >
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--iris)/0.15)]"
        >
          <svg
            class="h-4 w-4 text-[hsl(var(--iris))]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">2-minute timer</p>
          <p class="text-[10px] text-muted-foreground">Built-in pacing</p>
        </div>
      </div>
      <div
        class="flex items-center gap-3 rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] px-4 py-3"
      >
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--iris)/0.15)]"
        >
          <svg
            class="h-4 w-4 text-[hsl(var(--iris))]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
            ></path>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">Self-review ratings</p>
          <p class="text-[10px] text-muted-foreground">Track confidence</p>
        </div>
      </div>
      <div
        class="flex items-center gap-3 rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] px-4 py-3"
      >
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--iris)/0.15)]"
        >
          <svg
            class="h-4 w-4 text-[hsl(var(--iris))]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.03-.72a2.753 2.753 0 01-1.08-1.85 2.75 2.75 0 013.63-2.81 2.745 2.745 0 012.13.93"
            ></path>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">Session history</p>
          <p class="text-[10px] text-muted-foreground">See progress</p>
        </div>
      </div>
    </section>

    <section
      class="relative mx-auto mt-12 w-full max-w-6xl reveal"
      aria-labelledby="networking-guide-heading"
    >
      <div class="mb-8 border-t border-[hsl(var(--border)/0.4)] pt-8">
        <span class="eyebrow" style="color: hsl(var(--iris))">How it works</span>
        <h2
          id="networking-guide-heading"
          class="mt-3 text-2xl font-semibold tracking-tight text-foreground sm:text-3xl"
        >
          Rehearse the first two minutes
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3 reveal-stagger">
        <article
          class="rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] p-6 transition-colors duration-200 hover:border-[hsl(var(--iris)/0.4)] hover:bg-[hsl(var(--card)/0.7)]"
        >
          <div
            class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--iris)/0.15)]"
          >
            <svg
              class="h-5 w-5 text-[hsl(var(--iris))]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.637-2.346M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.637-2.346m0 0a3.375 3.375 0 116.374-2.346 3.375 3.375 0 01-6.374 2.346z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground">Pick a scenario</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            Choose from curated contexts like career fairs, coffee chats, virtual events, and alumni
            meetups. Each scenario gives you a realistic audience, a clear goal, and prompts
            tailored to that setting so your practice feels grounded.
          </p>
          <div
            class="mt-4 rounded-lg border border-[hsl(var(--iris)/0.2)] bg-[hsl(var(--iris)/0.06)] p-3"
          >
            <p class="eyebrow" style="color: hsl(var(--iris))">Tip</p>
            <p class="mt-1.5 text-xs leading-relaxed text-muted-foreground">
              Rotate between high-stakes and low-stakes scenarios to build adaptable confidence.
            </p>
          </div>
        </article>

        <article
          class="rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] p-6 transition-colors duration-200 hover:border-[hsl(var(--iris)/0.4)] hover:bg-[hsl(var(--card)/0.7)]"
        >
          <div
            class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--iris)/0.15)]"
          >
            <svg
              class="h-5 w-5 text-[hsl(var(--iris))]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground">Time your rep</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            Each scenario includes a built-in two-minute timer. Most people find that two to three
            reps per scenario builds confidence without fatigue. The timer keeps you concise and
            mirrors real conversation pressure.
          </p>
          <div
            class="mt-4 rounded-lg border border-[hsl(var(--iris)/0.2)] bg-[hsl(var(--iris)/0.06)] p-3"
          >
            <p class="eyebrow" style="color: hsl(var(--iris))">Tip</p>
            <p class="mt-1.5 text-xs leading-relaxed text-muted-foreground">
              Record yourself on the third rep. You will spot filler words and pacing issues
              instantly.
            </p>
          </div>
        </article>

        <article
          class="rounded-xl border border-[hsl(var(--border)/0.5)] bg-[hsl(var(--card)/0.5)] p-6 transition-colors duration-200 hover:border-[hsl(var(--iris)/0.4)] hover:bg-[hsl(var(--card)/0.7)]"
        >
          <div
            class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--iris)/0.15)]"
          >
            <svg
              class="h-5 w-5 text-[hsl(var(--iris))]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground">Review & refine</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            After each session, rate your clarity, energy, and message fit. The ratings and notes
            form a history you can revisit to see which scenarios still feel awkward and which ones
            you have mastered. Use the history to plan your next real networking event.
          </p>
          <div
            class="mt-4 rounded-lg border border-[hsl(var(--iris)/0.2)] bg-[hsl(var(--iris)/0.06)] p-3"
          >
            <p class="eyebrow" style="color: hsl(var(--iris))">Tip</p>
            <p class="mt-1.5 text-xs leading-relaxed text-muted-foreground">
              Look for patterns in your ratings. Low clarity usually means the story needs a
              concrete example.
            </p>
          </div>
        </article>
      </div>
    </section>
  </div>
</Base>
