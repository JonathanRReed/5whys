---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/contact/', siteConfig.siteUrl).toString();
const contactSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    '@id': `${pageUrl}#contact`,
    url: pageUrl,
    name: 'Contact 5 Whys Career Studio',
    description:
      'Contact page for 5 Whys Career Studio, including support and project inquiries.',
    isPartOf: {
      '@id': 'https://5whys.jonathanrreed.com/#website',
    },
    author: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
  },
];
---

<Base
  title="Contact"
  description="Contact 5 Whys Career Studio for project questions, tool feedback, privacy requests, or consulting context connected to the career tools."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Contact', href: '/contact/' },
  ]}
  structuredData={contactSchemas}
>
  <div class="relative space-y-10 overflow-hidden px-4 pb-16 pt-8 sm:pt-10">
    <section class="mx-auto w-full max-w-6xl">
      <PageHero
        eyebrow="Contact"
        title="Send feedback or project questions."
        description="Use the contact routes below for tool feedback, privacy requests, consulting context, or issues with exported career materials."
      />
    </section>

    <section class="mx-auto grid w-full max-w-4xl gap-6 md:grid-cols-2">
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 class="text-xl font-semibold text-foreground">Email</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          For product feedback, privacy requests, or general questions, email
          <a class="font-semibold text-foreground hover:text-accent" href="mailto:contact@helloworldfirm.com"> contact@helloworldfirm.com</a>.
        </p>
      </article>
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 class="text-xl font-semibold text-foreground">Portfolio</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          For more projects from Jonathan R Reed, visit the
          <a class="font-semibold text-foreground hover:text-accent" href="https://jonathanrreed.com/projects/"> portfolio</a>.
        </p>
      </article>
    </section>

    <section class="mx-auto w-full max-w-4xl space-y-4 text-base leading-relaxed text-muted-foreground">
      <p>
        Helpful reports include the page you were using, the browser and device, what you expected to happen, and whether
        the issue affected drafting, scoring, saving, exporting, navigation, or theme behavior. If a prompt feels unclear,
        include the wording that slowed you down and the kind of career situation you were trying to describe.
      </p>
      <p>
        For consulting or product questions, include the workflow you want to improve and whether you need research,
        design review, prototype work, security review, or a small internal tool. The same contact route can be used for
        accessibility feedback and privacy questions.
      </p>
      <p>
        If you are reporting a career-tool issue, do not send private employer documents or sensitive personal records.
        A short example, the page name, and the step that failed are usually enough to reproduce the problem and make the
        next update more useful.
      </p>
      <p>
        Good feedback is especially helpful when it explains the moment where the tool stopped matching the job-search
        task. That might be a confusing prompt, a score that did not reflect the draft, an export that needed a different
        format, or a navigation path that made it harder to return to unfinished work.
      </p>
      <p>
        For accessibility issues, mention the assistive technology, keyboard path, or screen size involved.
      </p>
      <p>
        Short, specific notes are easier to act on than full private drafts.
      </p>
    </section>
  </div>
</Base>
