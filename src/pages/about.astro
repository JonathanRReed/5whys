---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/about/', siteConfig.siteUrl).toString();
const aboutSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    '@id': `${pageUrl}#about`,
    url: pageUrl,
    name: 'About 5 Whys Career Studio',
    description:
      'About 5 Whys Career Studio, a set of practical career reflection and job search tools by Jonathan R Reed.',
    isPartOf: {
      '@id': 'https://5whys.jonathanrreed.com/#website',
    },
    primaryImageOfPage: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
    author: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
  },
];
---

<Base
  title="About 5 Whys"
  description="Learn about 5 Whys Career Studio, a practical set of career reflection, resume, networking, and interview preparation tools by Jonathan R Reed."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about/' },
  ]}
  structuredData={aboutSchemas}
>
  <div class="relative space-y-10 overflow-hidden px-4 pb-16 pt-8 sm:pt-10">
    <section class="mx-auto w-full max-w-6xl">
      <PageHero
        eyebrow="About"
        title="Career tools for clearer decisions."
        description="5 Whys Career Studio helps job seekers slow down, name what matters, and turn rough experience into stronger career stories."
      />
    </section>

    <section class="mx-auto grid w-full max-w-6xl gap-5 md:grid-cols-[1.2fr_0.9fr_0.9fr]">
      <article class="rounded-2xl border border-[hsl(var(--border)/0.3)] bg-[hsl(var(--overlay)/0.2)] p-6">
        <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.12)] text-[hsl(var(--foam))]">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
        </div>
        <h2 class="text-lg font-semibold text-foreground">Purpose</h2>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Practical reflection: five-layer career reasoning, resume scoring, networking rehearsal, and proof-based interview prep.
        </p>
      </article>
      <article class="rounded-2xl border border-[hsl(var(--border)/0.3)] bg-[hsl(var(--overlay)/0.2)] p-6">
        <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-[hsl(var(--iris)/0.12)] text-[hsl(var(--iris))]">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.25-.584-7.499-1.625z" /></svg>
        </div>
        <h2 class="text-lg font-semibold text-foreground">Creator</h2>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Jonathan R Reed. AI, cybersecurity, and developer tools. Keeping career workflows lightweight and private.
        </p>
      </article>
      <article class="rounded-2xl border border-[hsl(var(--border)/0.3)] bg-[hsl(var(--overlay)/0.2)] p-6">
        <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-[hsl(var(--gold)/0.12)] text-[hsl(var(--gold))]">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
        </div>
        <h2 class="text-lg font-semibold text-foreground">Approach</h2>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Structured prompts, local drafting, and exportable outputs. No signup required.
        </p>
      </article>
    </section>

    <section class="mx-auto w-full max-w-4xl space-y-5 text-base leading-relaxed text-muted-foreground">
      <p>
        The site is organized around small, repeatable sessions rather than long courses. Each page gives you an intentional
        place to draft, compare, and revise career material without turning the process into a heavy dashboard. You can
        use one tool before an application, return later for interview preparation, or keep the studio open while
        preparing notes for a networking conversation.
      </p>
      <p>
        The prompts are intentionally direct. They ask what changed, what evidence supports the claim, what tradeoff you
        accepted, and how the story should sound to another person. That structure helps turn vague confidence into
        usable language for resumes, interviews, and career planning conversations.
      </p>
      <p>
        The tools are intentionally narrow because career work gets better when the next action is obvious. A reflection
        session should produce a reason, a stronger bullet, a useful message, or a short interview packet, not another
        place to manage tasks.
      </p>
      <p>
        That focus also keeps the site useful during rushed job-search moments. You can open a single exercise, capture
        the evidence you already have, and leave with language that is easier to reuse in an application, recruiter
        reply, portfolio note, or interview prep document.
      </p>
    </section>
  </div>
</Base>
