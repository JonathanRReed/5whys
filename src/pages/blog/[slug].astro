---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const pageUrl = new URL(`/blog/${post.id}/`, siteConfig.siteUrl).toString();
const postSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    '@id': `${pageUrl}#post`,
    headline: post.data.title,
    description: post.data.description,
    url: pageUrl,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.updatedDate?.toISOString() ?? post.data.pubDate.toISOString(),
    inLanguage: 'en-US',
    author: {
      '@type': 'Person',
      name: post.data.author,
      url: siteConfig.author.url,
    },
    publisher: {
      '@id': 'https://jonathanrreed.com/#person',
    },
    image: post.data.ogImage
      ? new URL(post.data.ogImage, siteConfig.siteUrl).toString()
      : new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
    keywords: post.data.tags.join(', '),
    articleSection: post.data.category,
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': pageUrl,
    },
  },
];
---

<Base
  title={post.data.title}
  description={post.data.description}
  image={post.data.ogImage}
  type="article"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Blog', href: '/blog/' },
    { label: post.data.title, href: `/blog/${post.id}/` },
  ]}
  structuredData={postSchemas}
>
  <div class="relative overflow-hidden px-4 pb-20 pt-8 sm:pt-10">
    <article class="mx-auto w-full max-w-3xl">
      <header class="space-y-4 pb-10">
        <div class="flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center rounded-full bg-[hsl(var(--foam)/0.12)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.15em] text-[hsl(var(--foam))]">
            {post.data.category.replace('-', ' ')}
          </span>
          <time
            class="text-sm text-muted-foreground"
            datetime={post.data.pubDate.toISOString()}
          >
            {post.data.pubDate.toLocaleDateString('en-US', {
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            })}
          </time>
        </div>
        <h1 class="text-balance text-3xl font-semibold leading-[1.15] tracking-tight text-foreground sm:text-4xl lg:text-5xl">
          {post.data.title}
        </h1>
        <p class="max-w-2xl text-pretty text-base leading-relaxed text-muted-foreground">
          {post.data.description}
        </p>
        <div class="flex flex-wrap gap-2 pt-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full border border-[hsl(var(--border)/0.4)] bg-[hsl(var(--overlay)/0.2)] px-3 py-1 text-xs text-muted-foreground">
              #{tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose prose-invert max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-h2:text-2xl prose-h3:text-xl prose-p:text-base prose-p:leading-relaxed prose-p:text-muted-foreground prose-strong:text-foreground prose-a:text-[hsl(var(--foam))] prose-a:no-underline hover:prose-a:underline prose-blockquote:border-l-[hsl(var(--foam))] prose-blockquote:bg-[hsl(var(--overlay)/0.2)] prose-blockquote:py-2 prose-blockquote:px-4 prose-blockquote:rounded-r-xl prose-li:text-muted-foreground prose-thead:border-b-[hsl(var(--border))] prose-tr:border-b-[hsl(var(--border)/0.5)] prose-td:text-muted-foreground">
        <Content />
      </div>

      <footer class="mt-16 border-t border-[hsl(var(--border)/0.3)] pt-8">
        <div class="flex items-center gap-3">
          <div class="h-10 w-10 rounded-full bg-[hsl(var(--primary)/0.2)]" />
          <div>
            <p class="text-sm font-semibold text-foreground">{post.data.author}</p>
            <p class="text-xs text-muted-foreground">Career Tools Studio</p>
          </div>
        </div>
      </footer>
    </article>
  </div>
</Base>
