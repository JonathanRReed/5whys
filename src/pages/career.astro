---
import Base from '../layouts/Base.astro';
import Career5Whys from '../components/Career5Whys';
import ErrorBoundary from '../components/shared/ErrorBoundary';
import WithToasts from '../components/WithToasts';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/career/', siteConfig.siteUrl).toString();
const careerSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    '@id': `${pageUrl}#creativework`,
    url: pageUrl,
    name: 'Career Reflection · Five Whys',
    description:
      'Guided journaling exercise that helps you dig through five layers of reasoning to articulate your next career move.',
    inLanguage: 'en-US',
    author: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
    image: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the five whys exercise?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The five whys is a guided journaling technique where you ask "why" five times in succession to uncover the deeper motivation behind a career decision.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is my data stored securely?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'All data is stored locally in your browser. Nothing is sent to any server.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I export my reflection?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. You can export your complete reflection as a JSON file at any time.',
        },
      },
    ],
  },
];
---
<Base
  title="Career Reflection · Five Whys"
  description="Work through five guided layers of why to uncover the values, constraints, and impact signals that should guide your next career move."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Career Reflection', href: '/career/' },
  ]}
  structuredData={careerSchemas}
>
  <div class="relative overflow-hidden px-4 pb-16 pt-4 sm:pt-6">
    <h1 class="sr-only">Career Reflection Five Whys</h1>
    <section id="why-flow" class="mx-auto w-full max-w-6xl">
      <ErrorBoundary client:load>
        <WithToasts client:load>
          <Career5Whys
            client:load
            showHeader={false}
            showFooter={false}
            className="pb-8"
          />
        </WithToasts>
      </ErrorBoundary>
    </section>
    <section class="mx-auto mt-10 grid w-full max-w-6xl gap-6 md:grid-cols-3" aria-labelledby="career-guide-heading">
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 id="career-guide-heading" class="text-xl font-semibold text-foreground">Name the real reason</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          The five whys format is useful when a career answer sounds true but still feels too broad. Keep asking why
          until the reason names a value, constraint, skill, environment, or tradeoff you can act on.
        </p>
      </article>
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 class="text-xl font-semibold text-foreground">Turn notes into criteria</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          A good reflection session should produce decision criteria, not just a journal entry. Use the answers to decide
          what a role must offer, what you can compromise on, and which warning signs matter before the next interview.
        </p>
      </article>
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 class="text-xl font-semibold text-foreground">Reuse the outcome</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          The final summary can become interview language, a networking note, or a filter for job descriptions. Revisit
          it when a new opportunity looks attractive but does not match the reasons you already uncovered.
        </p>
      </article>
    </section>
  </div>
</Base>
