---
import Base from '../layouts/Base.astro';
import Career5Whys from '../components/Career5Whys';
import ErrorBoundary from '../components/shared/ErrorBoundary';
import WithToasts from '../components/WithToasts';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/career/', siteConfig.siteUrl).toString();
const careerSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    '@id': `${pageUrl}#creativework`,
    url: pageUrl,
    name: 'Career Reflection · Five Whys',
    description:
      'Guided journaling exercise that helps you dig through five layers of reasoning to articulate your next career move.',
    inLanguage: 'en-US',
    author: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
    image: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the five whys exercise?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The five whys is a guided journaling technique where you ask "why" five times in succession to uncover the deeper motivation behind a career decision.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is my data stored securely?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'All data is stored locally in your browser. Nothing is sent to any server.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I export my reflection?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. You can export your complete reflection as a JSON file at any time.',
        },
      },
    ],
  },
];
---
<Base
  title="Career Reflection · Five Whys"
  description="Work through five guided layers of why to uncover the values, constraints, and impact signals that should guide your next career move."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Career Reflection', href: '/career/' },
  ]}
  structuredData={careerSchemas}
>
  <div class="relative overflow-hidden px-4 pb-16 pt-4 sm:pt-6">
    <h1 class="sr-only">Career Reflection Five Whys</h1>
    <section id="why-flow" class="mx-auto w-full max-w-6xl">
      <ErrorBoundary client:load>
        <WithToasts client:load>
          <Career5Whys
            client:load
            showHeader={false}
            showFooter={false}
            className="pb-8"
          />
        </WithToasts>
      </ErrorBoundary>
    </section>

    {/* Quick Stats */}
    <section class="mx-auto mt-10 grid w-full max-w-6xl grid-cols-2 gap-3 sm:grid-cols-4" aria-label="Career tool quick stats">
      <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
          <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">5 guided prompts</p>
          <p class="text-[10px] text-muted-foreground">Layered whys</p>
        </div>
      </div>
      <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
          <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">Auto-generated summary</p>
          <p class="text-[10px] text-muted-foreground">At the end</p>
        </div>
      </div>
      <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
          <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">Export as JSON</p>
          <p class="text-[10px] text-muted-foreground">Portable data</p>
        </div>
      </div>
      <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
          <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-foreground">Local storage</p>
          <p class="text-[10px] text-muted-foreground">Private & safe</p>
        </div>
      </div>
    </section>

    {/* Guide section with gradient orb */}
    <section class="relative mx-auto mt-12 w-full max-w-6xl reveal" aria-labelledby="career-guide-heading">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="gradient-orb-animated absolute -top-24 right-0 h-72 w-72 rounded-full bg-[radial-gradient(circle_at_top_right,hsl(var(--foam)/0.18)_0%,transparent_60%)] blur-3xl"></div>
        <div class="gradient-orb-animated-reverse absolute bottom-0 -left-10 h-80 w-80 rounded-full bg-[radial-gradient(circle_at_bottom_left,hsl(var(--iris)/0.16)_0%,transparent_65%)] blur-[64px]"></div>
      </div>

      <div class="mb-8 text-center">
        <span class="text-xs font-semibold uppercase tracking-[0.3em] text-[hsl(var(--foam))]">How it works</span>
        <h2 id="career-guide-heading" class="mt-2 text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">Get clarity in five layers</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3 reveal-stagger">
        <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-[hsl(var(--border)/0.6)] hover:shadow-[0_20px_50px_-24px_hsl(var(--background)/0.8)]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--foam)/0.15)]">
            <svg class="h-5 w-5 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground">Name the real reason</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            The five whys format is useful when a career answer sounds true but still feels too broad. Keep asking why
            until the reason names a value, constraint, skill, environment, or tradeoff you can act on.
          </p>
          <div class="mt-4 rounded-xl bg-[hsl(var(--foam)/0.08)] p-3">
            <p class="text-xs text-[hsl(var(--foam))]">Pro tip: If your answer is "more money," ask what the money enables. That deeper reason usually reveals the real criteria.</p>
          </div>
        </article>

        <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-[hsl(var(--border)/0.6)] hover:shadow-[0_20px_50px_-24px_hsl(var(--background)/0.8)]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--foam)/0.15)]">
            <svg class="h-5 w-5 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.242 5.992h12m-12 6h12m-12 6h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground">Turn notes into criteria</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            A good reflection session should produce decision criteria, not just a journal entry. Use the answers to decide
            what a role must offer, what you can compromise on, and which warning signs matter before the next interview.
          </p>
          <div class="mt-4 rounded-xl bg-[hsl(var(--foam)/0.08)] p-3">
            <p class="text-xs text-[hsl(var(--foam))]">Pro tip: Write your top three must-haves on a sticky note and compare every new opportunity against them.</p>
          </div>
        </article>

        <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-[hsl(var(--border)/0.6)] hover:shadow-[0_20px_50px_-24px_hsl(var(--background)/0.8)]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--foam)/0.15)]">
            <svg class="h-5 w-5 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground">Reuse the outcome</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            The final summary can become interview language, a networking note, or a filter for job descriptions. Revisit
            it when a new opportunity looks attractive but does not match the reasons you already uncovered.
          </p>
          <div class="mt-4 rounded-xl bg-[hsl(var(--foam)/0.08)] p-3">
            <p class="text-xs text-[hsl(var(--foam))]">Pro tip: Revisit your summary every three months. Your priorities shift more than you think.</p>
          </div>
        </article>
      </div>
    </section>
  </div>
</Base>
