---
import Base from '../layouts/Base.astro';
import ResumeGameApp from '../components/ResumeGame';
import PageHero from '../components/PageHero.astro';
import { siteConfig } from '../config/site';

const pageUrl = new URL('/resume-game/', siteConfig.siteUrl).toString();
const resumeSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': `${pageUrl}#app`,
    name: 'Resume Game · Bullet Point Improvement',
    url: pageUrl,
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    description:
      'Interactive scoring system that helps you punch up resume bullets for clarity, action, and measurable impact.',
    creator: {
      '@type': 'Person',
      name: siteConfig.author.name,
      url: siteConfig.author.url,
    },
    image: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      ratingCount: '12',
      bestRating: '5',
      worstRating: '1',
    },
  },
];
---
<Base
  title="Resume Bullet Game"
  description="Score each resume bullet for action, clarity, and measurable impact, then rewrite weak lines into recruiter-ready career evidence."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Resume Game', href: '/resume-game/' },
  ]}
  structuredData={resumeSchemas}
>
  <div class="relative space-y-24 overflow-hidden px-4 pb-24 pt-24 sm:pt-32">
    <section class="mx-auto w-full max-w-6xl">
      <PageHero
        eyebrow="Career Lab"
        title="Rewrite every bullet into a high signal résumé line."
        description="Simulate an eight second recruiter scan, surface missing numbers and verbs, and draft stronger bullets with guided scoring."
      />
    </section>

    <section class="mx-auto grid w-full max-w-6xl gap-6 md:grid-cols-[1.1fr_0.9fr]">
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 class="text-xl font-semibold text-foreground">When to use it</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Use the Resume Bullet Game when a line sounds busy but does not yet prove impact. Paste one bullet at a time,
          check whether it has a clear action, audience, result, and measure, then rewrite it until the evidence is easy
          to scan. It is built for early drafts, final polish, and quick reviews before applications.
        </p>
      </article>
      <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6">
        <h2 class="text-xl font-semibold text-foreground">What the score means</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          The score is a drafting aid, not a hiring prediction. Strong bullets usually name the work, show scale, explain
          the result, and avoid vague verbs. A lower score points to the next rewrite target so you can improve the line
          without guessing what feels weak.
        </p>
      </article>
    </section>

    <section class="mx-auto w-full max-w-6xl">
      <ResumeGameApp client:load showHeader={false} className="rounded-[2.5rem] border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 pb-16 pt-10 sm:px-6 overflow-hidden" />
    </section>
  </div>
</Base>
