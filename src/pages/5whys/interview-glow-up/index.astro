---
import Base from "../../../layouts/Base.astro";
import InterviewGlowUpAdvice from "../../../components/InterviewGlowUp/InterviewGlowUpAdvice";
import { siteConfig } from "../../../config/site";

const pageUrl = new URL(
    "/5whys/interview-glow-up",
    siteConfig.siteUrl,
).toString();
const glowUpSchemas = [
    {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "@id": `${pageUrl}#howto`,
        url: pageUrl,
        name: "Interview Glow Up - Prepare for Interviews with Confidence",
        description:
            "Transform interview anxiety into confidence. Learn the Play + Proof method, decode job descriptions, and build a panic-proof interview packet.",
        inLanguage: "en-US",
        author: {
            "@type": "Person",
            name: siteConfig.author.name,
            url: siteConfig.author.url,
        },
        image: new URL(siteConfig.ogImage, siteConfig.siteUrl).toString(),
        aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: "4.9",
            ratingCount: "15",
            bestRating: "5",
            worstRating: "1",
        },
        step: [
            {
                "@type": "HowToStep",
                name: "Understand interview anxiety",
                text: "Recognize that feeling nervous is normal and that the 'exam mindset' triggers fight, flight, or freeze mode. This awareness is the first step to overcoming it.",
            },
            {
                "@type": "HowToStep",
                name: "Learn the Play + Proof method",
                text: "Shift from rehearsing scripted answers to preparing proof-based stories that demonstrate your real experience and accomplishments.",
            },
            {
                "@type": "HowToStep",
                name: "Decode the job description",
                text: "Analyze what recruiters actually want by breaking down the job description into key requirements and matching them to your experience.",
            },
            {
                "@type": "HowToStep",
                name: "Build your interview packet",
                text: "Create a panic-proof cheat sheet with your stories, key points, and proof that you can reference before or during the interview.",
            },
        ],
    },
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: [
            {
                "@type": "Question",
                name: "What is the Play + Proof method?",
                acceptedAnswer: {
                    "@type": "Answer",
                    text: "The Play + Proof method shifts interview preparation from memorizing scripted answers to building a library of proof-based stories that demonstrate real experience and accomplishments.",
                },
            },
            {
                "@type": "Question",
                name: "How do I decode a job description?",
                acceptedAnswer: {
                    "@type": "Answer",
                    text: "Paste the job description into the decoder to automatically extract required skills, responsibilities, and key themes. Then match them against your own experience to identify gaps and strengths.",
                },
            },
            {
                "@type": "Question",
                name: "Is my interview data private?",
                acceptedAnswer: {
                    "@type": "Answer",
                    text: "Yes. All job descriptions, stories, and packets are stored locally in your browser. Nothing is sent to any server.",
                },
            },
        ],
    },
];
---

<Base
    title="Interview Glow Up"
    description="Transform interview anxiety into confidence. Decode job descriptions, build proof-based stories, and create a panic-proof interview packet in 20 minutes."
    breadcrumbs={[
        { label: "Home", href: "/" },
        { label: "Interview Glow Up", href: "/5whys/interview-glow-up/" },
    ]}
    structuredData={glowUpSchemas}
>
    <div class="relative overflow-hidden px-4 pb-16 pt-4 sm:pt-6">
        <h1 class="sr-only">Interview Glow Up</h1>
        <section class="mx-auto w-full max-w-6xl">
            <InterviewGlowUpAdvice client:load />
        </section>

        {/* Quick Stats */}
        <section class="mx-auto mt-10 grid w-full max-w-6xl grid-cols-2 gap-3 sm:grid-cols-4 reveal" aria-label="Interview glow up quick stats">
            <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
                    <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-foreground">JD decoding</p>
                    <p class="text-[10px] text-muted-foreground">Extract signals</p>
                </div>
            </div>
            <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
                    <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-foreground">STAR story builder</p>
                    <p class="text-[10px] text-muted-foreground">Proof-based prep</p>
                </div>
            </div>
            <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
                    <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-foreground">Interview packet</p>
                    <p class="text-[10px] text-muted-foreground">Panic-proof notes</p>
                </div>
            </div>
            <div class="flex items-center gap-3 rounded-2xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] px-4 py-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[hsl(var(--foam)/0.15)]">
                    <svg class="h-4 w-4 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-foreground">Panic-proof HUD</p>
                    <p class="text-[10px] text-muted-foreground">At-a-glance prep</p>
                </div>
            </div>
        </section>

        {/* Guide section with gradient orb */}
        <section class="relative mx-auto mt-12 w-full max-w-6xl reveal" aria-labelledby="interview-guide-heading">
            <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
                <div class="gradient-orb-animated absolute -top-24 right-0 h-72 w-72 rounded-full bg-[radial-gradient(circle_at_top_right,hsl(var(--foam)/0.18)_0%,transparent_60%)] blur-3xl"></div>
                <div class="gradient-orb-animated-reverse absolute bottom-0 -left-10 h-80 w-80 rounded-full bg-[radial-gradient(circle_at_bottom_left,hsl(var(--iris)/0.16)_0%,transparent_65%)] blur-[64px]"></div>
            </div>

            <div class="mb-8 text-center">
                <span class="text-xs font-semibold uppercase tracking-[0.3em] text-[hsl(var(--foam))]">How it works</span>
                <h2 id="interview-guide-heading" class="mt-2 text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">Prep with proof, not scripts</h2>
            </div>

            <div class="grid gap-6 md:grid-cols-3 reveal-stagger">
                <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-[hsl(var(--border)/0.6)] hover:shadow-[0_20px_50px_-24px_hsl(var(--background)/0.8)]">
                    <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--foam)/0.15)]">
                        <svg class="h-5 w-5 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-foreground">Decode the JD</h3>
                    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                        Paste a job description to automatically extract required skills, responsibilities, and key themes.
                        Then match them against your own experience to identify gaps and strengths before the interview.
                    </p>
                    <div class="mt-4 rounded-xl bg-[hsl(var(--foam)/0.08)] p-3">
                        <p class="text-xs text-[hsl(var(--foam))]">Pro tip: Look for repeated phrases. If "cross-functional" appears three times, prepare a story that shows collaboration.</p>
                    </div>
                </article>

                <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-[hsl(var(--border)/0.6)] hover:shadow-[0_20px_50px_-24px_hsl(var(--background)/0.8)]">
                    <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--foam)/0.15)]">
                        <svg class="h-5 w-5 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-foreground">Build STAR stories</h3>
                    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                        Shift from rehearsing scripted answers to preparing proof-based stories. Use the STAR builder to
                        capture Situation, Task, Action, and Result for each key requirement so you never blank under pressure.
                    </p>
                    <div class="mt-4 rounded-xl bg-[hsl(var(--foam)/0.08)] p-3">
                        <p class="text-xs text-[hsl(var(--foam))]">Pro tip: Write the Result first. If it is not impressive, the story needs a different example.</p>
                    </div>
                </article>

                <article class="rounded-3xl border border-[hsl(var(--border)/0.35)] bg-[hsl(var(--overlay)/0.25)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-[hsl(var(--border)/0.6)] hover:shadow-[0_20px_50px_-24px_hsl(var(--background)/0.8)]">
                    <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(var(--foam)/0.15)]">
                        <svg class="h-5 w-5 text-[hsl(var(--foam))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-foreground">Assemble your packet</h3>
                    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                        Create a panic-proof cheat sheet with your stories, key points, and proof that you can reference
                        before or during the interview. The packet view keeps everything at a glance so you walk in calm and ready.
                    </p>
                    <div class="mt-4 rounded-xl bg-[hsl(var(--foam)/0.08)] p-3">
                        <p class="text-xs text-[hsl(var(--foam))]">Pro tip: Print or screenshot your packet. Having a physical backup reduces last-minute anxiety.</p>
                    </div>
                </article>
            </div>
        </section>
    </div>
</Base>
