---
import { siteConfig, baseSchemas } from '../config/site';
import Seo from '../components/Seo.astro';
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation';
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/fraunces/full-italic.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/globals.css';

const {
  title = siteConfig.siteName,
  description = siteConfig.description,
  theme = 'night',
  image = siteConfig.ogImage,
  noindex = false,
  canonical,
  type = 'website',
  structuredData = [],
  breadcrumbs = [{ label: 'Home', href: '/' }],
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const breadcrumbList = breadcrumbs.map((crumb: { label: string; href: string }, index: number) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: crumb.label,
  item: new URL(crumb.href, siteConfig.siteUrl).toString(),
}));

const breadcrumbSchema =
  breadcrumbList.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbList,
      }
    : null;

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: 'en-US',
  isPartOf: {
    '@id': baseSchemas.website['@id'],
  },
};

const additionalSchemas = Array.isArray(structuredData) ? structuredData : [structuredData];
const schemaPayload = [
  baseSchemas.website,
  baseSchemas.creator,
  pageSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...additionalSchemas.filter(Boolean),
];
---

<html
  lang="en"
  class={`h-full ${theme === 'dawn' ? 'theme-dawn' : 'theme-night'}`}
  data-theme={theme === 'dawn' ? 'dawn' : 'night'}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content={theme === 'dawn' ? 'only light' : 'dark'} />
    <script is:inline src="/career-tools-theme.js"></script>
    <Seo
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      canonical={canonicalUrl}
      type={type}
      structuredData={schemaPayload}
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link
      rel="preload"
      as="image"
      href="/career-studio-mark-nav-1x.png"
      imagesrcset="/career-studio-mark-nav-1x.png 1x, /career-studio-mark-nav.png 2x"
    />
    <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-background text-foreground transition-colors duration-300">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-[hsl(var(--primary))] focus:px-4 focus:py-2 focus:text-[hsl(var(--primary-foreground))]"
    >
      Skip to main content
    </a>
    <!-- Signature blueprint grid: a faint, precise Swiss grid fading from the top -->
    <div aria-hidden="true" class="bg-blueprint pointer-events-none fixed inset-0 z-0 opacity-70">
    </div>
    <!-- Subtle grain texture overlay for premium matte finish -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-50 opacity-[0.015]"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"
    >
    </div>
    <div class="relative flex min-h-screen flex-col">
      <Navigation client:load currentPath={Astro.url.pathname} />
      <main id="main-content" class="relative z-10 flex-1" transition:name="page-content">
        <slot />
      </main>
      <footer
        role="contentinfo"
        class="relative z-10 mx-auto mt-20 w-full max-w-6xl px-4 transition-colors duration-300"
      >
        <div class="border-t border-[hsl(var(--border)/0.5)] pt-10">
          <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
            <div class="space-y-3">
              <div class="flex items-center gap-2.5">
                <span
                  aria-hidden="true"
                  class="flex h-8 w-8 items-center justify-center rounded-lg border border-[hsl(var(--border)/0.6)] bg-[hsl(var(--card)/0.8)]"
                >
                  <svg class="h-5 w-5 text-foreground" viewBox="0 0 36 36" fill="none">
                    <rect
                      x="6"
                      y="6"
                      width="24"
                      height="2.6"
                      rx="1.3"
                      fill="currentColor"
                      fill-opacity="0.85"></rect>
                    <rect
                      x="9"
                      y="13"
                      width="18"
                      height="2.6"
                      rx="1.3"
                      fill="currentColor"
                      fill-opacity="0.6"></rect>
                    <rect
                      x="12"
                      y="20"
                      width="12"
                      height="2.6"
                      rx="1.3"
                      fill="currentColor"
                      fill-opacity="0.4"></rect>
                    <rect x="15" y="27" width="6" height="2.6" rx="1.3" fill="hsl(var(--primary))"
                    ></rect>
                  </svg>
                </span>
                <span class="font-display text-base font-semibold tracking-tight text-foreground"
                  >5 Whys Career Studio</span
                >
              </div>
              <p class="max-w-xs text-sm leading-relaxed text-muted-foreground">
                A small studio of career tools that helps you find the real reason, then build the
                proof. Private by design: everything stays in your browser.
              </p>
            </div>

            <nav aria-label="Studio" class="space-y-3">
              <p class="eyebrow">Studio</p>
              <ul class="space-y-2.5 text-sm">
                <li>
                  <a
                    href="/about/"
                    class="text-muted-foreground transition-colors hover:text-foreground">About</a
                  >
                </li>
                <li>
                  <a
                    href="/contact/"
                    class="text-muted-foreground transition-colors hover:text-foreground">Contact</a
                  >
                </li>
                <li>
                  <a
                    href="/privacy/"
                    class="text-muted-foreground transition-colors hover:text-foreground">Privacy</a
                  >
                </li>
                <li>
                  <a
                    href="/start/"
                    class="text-muted-foreground transition-colors hover:text-foreground"
                    >Start here</a
                  >
                </li>
              </ul>
            </nav>

            <nav aria-label="More from Jonathan" class="space-y-3">
              <p class="eyebrow">Elsewhere</p>
              <ul class="space-y-2.5 text-sm">
                <li>
                  <a
                    href="https://jonathanrreed.com/projects/"
                    class="text-muted-foreground transition-colors hover:text-foreground"
                    >Portfolio</a
                  >
                </li>
                <li>
                  <a
                    href="https://semesterbuild.jonathanrreed.com/"
                    class="text-muted-foreground transition-colors hover:text-foreground"
                    >Semester Build</a
                  >
                </li>
                <li>
                  <a
                    href="https://dev-tools.helloworldfirm.com/"
                    class="text-muted-foreground transition-colors hover:text-foreground"
                    >Simple Dev Tools</a
                  >
                </li>
              </ul>
            </nav>
          </div>

          <div
            class="mt-10 flex flex-col gap-2 border-t border-[hsl(var(--border)/0.4)] pt-6 text-xs text-muted-foreground sm:flex-row sm:items-center sm:justify-between"
          >
            <p>
              Made by <a
                href="https://jonathanrreed.com"
                class="font-medium text-foreground transition-colors hover:text-[hsl(var(--accent))]"
                >Jonathan R. Reed</a
              >
            </p>
            <p class="eyebrow text-[0.62rem]">No account · No tracking · Open source</p>
          </div>
        </div>
      </footer>
      <script is:inline src="/career-tools-effects.js"></script>
    </div>
  </body>
</html>
