---
interface Props {
  href: string;
  title: string;
  description: string;
  accent?: 'love' | 'gold' | 'foam' | 'iris' | 'pine';
  cta?: string;
  tag?: string;
  index?: string;
}

const { href, title, description, accent = 'foam', cta = 'Open tool', tag, index } = Astro.props;
---

<a
  href={href}
  class="group relative grid h-full grid-rows-[auto,auto,1fr,auto] gap-5 overflow-hidden rounded-2xl border border-[hsl(var(--border)/0.4)] bg-[hsl(var(--card)/0.45)] p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-[hsl(var(--card-accent)/0.55)] hover:bg-[hsl(var(--card)/0.7)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[hsl(var(--ring))] focus-visible:ring-offset-2 focus-visible:ring-offset-[hsl(var(--background))] md:p-7"
  style={`--card-accent: var(--${accent});`}
>
  {/* Top accent rule that draws in on hover */}
  <span
    class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-[hsl(var(--card-accent))] transition-transform duration-300 group-hover:scale-x-100"
    aria-hidden="true"></span>

  {/* Index marker + tag */}
  <div class="flex items-center justify-between">
    {
      index && (
        <span class="num-index text-xs text-[hsl(var(--card-accent))]" aria-hidden="true">
          {index}
        </span>
      )
    }
    {tag && <span class="eyebrow text-[0.6rem] text-muted-foreground">{tag}</span>}
  </div>

  {/* Icon */}
  <div
    class="card-icon-lift flex h-11 w-11 items-center justify-center rounded-lg border border-[hsl(var(--card-accent)/0.25)] bg-[hsl(var(--card-accent)/0.1)] text-[hsl(var(--card-accent))]"
  >
    <slot name="icon" />
  </div>

  <div class="space-y-2">
    <h2 class="text-xl font-semibold leading-snug tracking-tight text-foreground">
      {title}
    </h2>
    <p class="text-sm leading-relaxed text-muted-foreground">
      {description}
    </p>
  </div>

  <div class="flex items-center gap-1.5 text-sm font-medium text-[hsl(var(--card-accent))]">
    {cta}
    <svg
      class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
    </svg>
  </div>
</a>
